generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())

  // Audit relations
  ordersCreated   Order[]   @relation("OrderCreatedBy")
  ordersUpdated   Order[]   @relation("OrderUpdatedBy")
  ordersDeleted   Order[]   @relation("OrderDeletedBy")
  expensesCreated Expense[] @relation("ExpenseCreatedBy")
  expensesUpdated Expense[] @relation("ExpenseUpdatedBy")
  expensesDeleted Expense[] @relation("ExpenseDeletedBy")
  salesCreated    Sale[]    @relation("SaleCreatedBy")
  salesUpdated    Sale[]    @relation("SaleUpdatedBy")
  salesDeleted    Sale[]    @relation("SaleDeletedBy")
}

model Order {
  id        String      @id @default(cuid())
  customer  String
  phone     String
  address   String
  product   String
  quantity  Int
  amount    Float
  status    OrderStatus @default(PENDING)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  // Audit fields
  createdBy   String?
  updatedBy   String?
  deletedAt   DateTime?
  deletedBy   String?

  createdByAdmin Admin? @relation("OrderCreatedBy", fields: [createdBy], references: [id])
  updatedByAdmin Admin? @relation("OrderUpdatedBy", fields: [updatedBy], references: [id])
  deletedByAdmin Admin? @relation("OrderDeletedBy", fields: [deletedBy], references: [id])
}

model Expense {
  id          String   @id @default(cuid())
  title       String
  amount      Float
  category    String
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  // Audit fields
  createdBy   String?
  updatedBy   String?
  deletedAt   DateTime?
  deletedBy   String?

  createdByAdmin Admin? @relation("ExpenseCreatedBy", fields: [createdBy], references: [id])
  updatedByAdmin Admin? @relation("ExpenseUpdatedBy", fields: [updatedBy], references: [id])
  deletedByAdmin Admin? @relation("ExpenseDeletedBy", fields: [deletedBy], references: [id])
}

model Sale {
  id            String        @id @default(cuid())
  customer      String
  phone         String?
  product       String
  quantity      Int
  amount        Float
  paymentMethod PaymentMethod
  description   String?
  date          DateTime      @default(now())
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Audit fields
  createdBy   String?
  updatedBy   String?
  deletedAt   DateTime?
  deletedBy   String?

  createdByAdmin Admin? @relation("SaleCreatedBy", fields: [createdBy], references: [id])
  updatedByAdmin Admin? @relation("SaleUpdatedBy", fields: [updatedBy], references: [id])
  deletedByAdmin Admin? @relation("SaleDeletedBy", fields: [deletedBy], references: [id])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  CASH
  ONLINE
  CREDIT
}
