generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())

  // Audit relations
  ordersCreated   Order[]   @relation("OrderCreatedBy")
  ordersUpdated   Order[]   @relation("OrderUpdatedBy")
  ordersDeleted   Order[]   @relation("OrderDeletedBy")
  expensesCreated Expense[] @relation("ExpenseCreatedBy")
  expensesUpdated Expense[] @relation("ExpenseUpdatedBy")
  expensesDeleted Expense[] @relation("ExpenseDeletedBy")
  salesCreated    Sale[]    @relation("SaleCreatedBy")
  salesUpdated    Sale[]    @relation("SaleUpdatedBy")
  salesDeleted    Sale[]    @relation("SaleDeletedBy")
  enquiriesUpdated Enquiry[] @relation("EnquiryUpdatedBy")
  enquiriesDeleted Enquiry[] @relation("EnquiryDeletedBy")
  b2bCreated      B2BClient[] @relation("B2BCreatedBy")
  b2bUpdated      B2BClient[] @relation("B2BUpdatedBy")
  b2bDeleted      B2BClient[] @relation("B2BDeletedBy")
}

model Order {
  id        String      @id @default(cuid())
  customer  String
  phone     String
  address   String
  product   String
  quantity  Int
  amount    Float
  status    OrderStatus @default(PENDING)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  // Audit fields
  createdBy   String?
  updatedBy   String?
  deletedAt   DateTime?
  deletedBy   String?

  createdByAdmin Admin? @relation("OrderCreatedBy", fields: [createdBy], references: [id])
  updatedByAdmin Admin? @relation("OrderUpdatedBy", fields: [updatedBy], references: [id])
  deletedByAdmin Admin? @relation("OrderDeletedBy", fields: [deletedBy], references: [id])
}

model Expense {
  id          String   @id @default(cuid())
  title       String
  amount      Float
  category    String
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  // Audit fields
  createdBy   String?
  updatedBy   String?
  deletedAt   DateTime?
  deletedBy   String?

  createdByAdmin Admin? @relation("ExpenseCreatedBy", fields: [createdBy], references: [id])
  updatedByAdmin Admin? @relation("ExpenseUpdatedBy", fields: [updatedBy], references: [id])
  deletedByAdmin Admin? @relation("ExpenseDeletedBy", fields: [deletedBy], references: [id])
}

model Sale {
  id            String        @id @default(cuid())
  customer      String
  phone         String?
  product       String
  quantity      Int
  amount        Float
  paymentMethod PaymentMethod
  description   String?
  date          DateTime      @default(now())
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Audit fields
  createdBy   String?
  updatedBy   String?
  deletedAt   DateTime?
  deletedBy   String?

  createdByAdmin Admin? @relation("SaleCreatedBy", fields: [createdBy], references: [id])
  updatedByAdmin Admin? @relation("SaleUpdatedBy", fields: [updatedBy], references: [id])
  deletedByAdmin Admin? @relation("SaleDeletedBy", fields: [deletedBy], references: [id])
}

model Enquiry {
  id        String        @id @default(cuid())
  name      String
  contact   String        // email or phone the customer gave
  type      EnquiryType   @default(OTHER)
  message   String
  status    EnquiryStatus @default(NEW)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  // Audit fields (no createdBy — these come from the public contact form)
  updatedBy String?
  deletedAt DateTime?
  deletedBy String?

  updatedByAdmin Admin? @relation("EnquiryUpdatedBy", fields: [updatedBy], references: [id])
  deletedByAdmin Admin? @relation("EnquiryDeletedBy", fields: [deletedBy], references: [id])
}

model B2BClient {
  id            String   @id @default(cuid())
  shopName      String
  contactPerson String?
  phone         String   // main contact number
  altPhone      String?
  email         String?
  type          B2BType  @default(RETAILER)
  address       String
  mapUrl        String?  // Google Maps link to the shop's pin
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Audit fields
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
  deletedBy String?

  createdByAdmin Admin? @relation("B2BCreatedBy", fields: [createdBy], references: [id])
  updatedByAdmin Admin? @relation("B2BUpdatedBy", fields: [updatedBy], references: [id])
  deletedByAdmin Admin? @relation("B2BDeletedBy", fields: [deletedBy], references: [id])
}

enum B2BType {
  RETAILER
  WHOLESALER
  DISTRIBUTOR
  CAFE_RESTAURANT
  SUPERMARKET
  OTHER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum EnquiryType {
  B2C
  B2B
  GIFTING
  PARTNERSHIP
  OTHER
}

enum EnquiryStatus {
  NEW
  READ
  REPLIED
  ARCHIVED
}

enum PaymentMethod {
  CASH
  ONLINE
  CREDIT
}
